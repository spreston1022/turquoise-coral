{
  "openapi": "3.1.0",
  "info": {
    "version": "1.0.0",
    "title": "MCP Gateway"
  },
  "paths": {
    "/mcp": {
      "get,post": {
        "operationId": "mcp-demo-server",
        "summary": "MCP Demo Server",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "module": "$import(@zuplo/runtime/mcp-gateway)",
            "export": "McpProxyHandler",
            "options": {
              "rewritePattern": "https://demo-mcp-server.spreston1022.workers.dev/mcp"
            }
          },
          "policies": {
            "inbound": [
              "auth0-managed-oauth",
              "log-mcp-request",
              "authz-mcp-tools",
              "inject-gateway-secret",
              "custom-code-inbound"
            ]
          }
        }
      }
    }
  }
}