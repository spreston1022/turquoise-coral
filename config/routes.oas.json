{
  "openapi": "3.1.0",
  "info": {
    "version": "1.0.0",
    "title": "MCP Gateway"
  },
  "paths": {
    "/mcp": {
      "get,post": {
        "operationId": "mcp-demo-server",
        "summary": "MCP Demo Server",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "module": "$import(@zuplo/runtime/mcp-gateway)",
            "export": "McpProxyHandler",
            "options": {
              "rewritePattern": "${env.MCP_UPSTREAM_URL}"
            }
          },
          "policies": {
            "inbound": ["log-upstream-url", "auth0-managed-oauth", "inject-gateway-secret"]
          }
        }
      }
    }
  }
}
