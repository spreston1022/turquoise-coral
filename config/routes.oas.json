{
  "openapi": "3.1.0",
  "info": {
    "version": "1.0.0",
    "title": "MCP Gateway"
  },
  "servers": [
    {
      "url": "https://turquoise-coral-main-d16656d.zuplo.app",
      "description": "Production gateway"
    }
  ],
  "paths": {
    "/mcp": {
      "get": {
        "operationId": "mcp-demo-server-stream",
        "summary": "MCP Demo Server (SSE stream)",
        "x-internal": true,
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "module": "$import(@zuplo/runtime/mcp-gateway)",
            "export": "McpProxyHandler",
            "options": {
              "rewritePattern": "https://demo-mcp-server.spreston1022.workers.dev/mcp"
            }
          },
          "policies": {
            "inbound": [
              "auth0-managed-oauth",
              "log-mcp-request",
              "authz-mcp-tools",
              "inject-gateway-secret",
              "custom-code-inbound"
            ]
          }
        }
      },
      "post": {
        "operationId": "mcp-demo-server",
        "summary": "MCP Demo Server",
        "description": "Remote MCP server exposing demo tools behind Zuplo's MCP Gateway. Requires signing in via Auth0 OAuth.\n\n**Available tools:**\n- `echo` — echoes back the provided message\n- `get_current_time` — returns the current server time (requires `time:read` scope)\n- `generate_uuid` — generates a random UUID",
        "x-mcp-server": {
          "name": "demo-mcp-server",
          "version": "1.0.0",
          "tools": [
            { "name": "echo", "description": "Echoes back the provided message" },
            { "name": "get_current_time", "description": "Returns the current server time (requires time:read scope)" },
            { "name": "generate_uuid", "description": "Generates a random UUID" }
          ]
        },
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "module": "$import(@zuplo/runtime/mcp-gateway)",
            "export": "McpProxyHandler",
            "options": {
              "rewritePattern": "https://demo-mcp-server.spreston1022.workers.dev/mcp"
            }
          },
          "policies": {
            "inbound": [
              "auth0-managed-oauth",
              "log-mcp-request",
              "authz-mcp-tools",
              "inject-gateway-secret",
              "custom-code-inbound"
            ]
          }
        }
      }
    },
    "/.well-known/ai-catalog.json": {
      "get": {
        "operationId": "ard-catalog",
        "summary": "Agentic Resource Discovery catalog",
        "x-internal": true,
        "x-zuplo-route": {
          "corsPolicy": "anything-goes",
          "handler": {
            "export": "handleWellKnown",
            "module": "$import(./modules/well-known)"
          },
          "policies": {
            "inbound": []
          }
        }
      }
    }
  }
}