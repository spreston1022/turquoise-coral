# Auth0 application credentials (create a Regular Web Application in Auth0)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret

# Auth0 API identifier (create an API in Auth0 with RBAC enabled)
AUTH0_AUDIENCE=https://turquoise-coral-main-d16656d.zuplo.app

# URL of your deployed Cloudflare Worker MCP server
MCP_UPSTREAM_URL=https://demo-mcp-server.YOUR_SUBDOMAIN.workers.dev/mcp

# Shared secret between Zuplo and the CF Worker — generate with: openssl rand -hex 32
GATEWAY_SECRET=your-generated-secret
